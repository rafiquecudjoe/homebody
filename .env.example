# Required - get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
PORT=3000
MODEL=claude-sonnet-4-6
MAX_TOKENS=1000

# Comma-separated list of origins allowed to call /api/chat.
# Must be the EXACT origin where the front-end HTML is hosted.
ALLOWED_ORIGINS=https://cherrymenlove.com,https://www.cherrymenlove.com

# Rate limit per IP per window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Hard global cap on total Anthropic tokens (input+output) per UTC day.
# Stops cost blowup if an attacker rotates IPs around the per-IP rate limit.
# Set high enough for legitimate traffic, low enough to bound disaster.
DAILY_TOKEN_CAP=2000000

# Abort upstream Anthropic calls after this many ms (frees sockets if API hangs)
UPSTREAM_TIMEOUT_MS=30000

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
